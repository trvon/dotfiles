{
  "id": "pi-context",
  "name": "Pi Context",
  "description": "Local plugin workspace for Pi-style RLM and context management.",
  "version": "0.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabledRlm": {
        "type": "boolean",
        "default": true
      },
      "enabledDcs": {
        "type": "boolean",
        "default": false
      },
      "yamsBinary": {
        "type": "string",
        "default": "yams"
      },
      "yamsCwd": {
        "type": "string"
      },
      "rlmCollection": {
        "type": "string",
        "default": "pi-session-memory"
      },
      "rlmSimilarity": {
        "type": "number",
        "default": 0.001
      },
      "rlmLimit": {
        "type": "integer",
        "minimum": 1,
        "default": 3
      },
      "autoStore": {
        "type": "boolean",
        "default": true
      },
      "storeLimit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 8,
        "default": 3
      },
      "continuityWatchdogEnabled": {
        "type": "boolean",
        "default": true
      },
      "continuityMaxRetries": {
        "type": "integer",
        "minimum": 0,
        "maximum": 3,
        "default": 1
      },
      "continuityCooldownMs": {
        "type": "integer",
        "minimum": 0,
        "default": 120000
      },
      "activityHeartbeatEnabled": {
        "type": "boolean",
        "default": true
      },
      "activityHeartbeatMs": {
        "type": "integer",
        "minimum": 60000,
        "default": 1800000
      },
      "activityHeartbeatPollMs": {
        "type": "integer",
        "minimum": 30000,
        "default": 300000
      },
      "lmstudioBaseUrl": {
        "type": "string",
        "default": "http://host.docker.internal:1234/v1"
      },
      "sidecarModel": {
        "type": "string",
        "default": "qwen_qwen3.5-4b"
      },
      "dcsCli": {
        "type": "string",
        "default": "research-agent"
      },
      "dcsContextProfile": {
        "type": "string",
        "enum": ["auto", "standard", "small", "large"],
        "default": "small"
      }
    }
  },
  "uiHints": {
    "enabledRlm": {
      "label": "Enable RLM"
    },
    "enabledDcs": {
      "label": "Enable DCS"
    },
    "yamsBinary": {
      "label": "YAMS Binary"
    },
    "yamsCwd": {
      "label": "YAMS Working Dir"
    },
    "rlmCollection": {
      "label": "RLM Collection"
    },
    "rlmSimilarity": {
      "label": "RLM Similarity"
    },
    "rlmLimit": {
      "label": "RLM Result Limit"
    },
    "autoStore": {
      "label": "Auto Store Memory"
    },
    "storeLimit": {
      "label": "Store Limit"
    },
    "continuityWatchdogEnabled": {
      "label": "Continuity Watchdog"
    },
    "continuityMaxRetries": {
      "label": "Continuity Max Retries"
    },
    "continuityCooldownMs": {
      "label": "Continuity Cooldown (ms)"
    },
    "activityHeartbeatEnabled": {
      "label": "Activity Heartbeat"
    },
    "activityHeartbeatMs": {
      "label": "Activity Heartbeat Threshold (ms)"
    },
    "activityHeartbeatPollMs": {
      "label": "Activity Heartbeat Poll (ms)"
    },
    "lmstudioBaseUrl": {
      "label": "LM Studio Base URL"
    },
    "sidecarModel": {
      "label": "Sidecar Model"
    },
    "dcsCli": {
      "label": "DCS CLI"
    },
    "dcsContextProfile": {
      "label": "DCS Context Profile"
    }
  }
}
